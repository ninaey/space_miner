PORT=8080
DATABASE_URL=postgres://postgres:123456@localhost:5432/spaceminergame?sslmode=disable

XSOLLA_PROJECT_ID=your_numeric_project_id
XSOLLA_MERCHANT_ID=your_merchant_id
# API key from Publisher Account → Company Settings → API Keys
# Must have "Store" and "PayStation" permissions enabled
XSOLLA_API_KEY=your_api_key

# PayStation token (admin/payment/token) — fixes many 422 / [0401-2000] issues when aligned with the project
# true = sandbox payments (default). Set false if PayStation is only enabled for live in Publisher Account.
XSOLLA_PAYSTATION_SANDBOX=true
# Optional. Leave empty to let Xsolla pick currency from catalog / user region (recommended if prices are regional).
# Example for Malaysia ringgit: MYR
XSOLLA_PAYSTATION_CURRENCY=
XSOLLA_PAYSTATION_LANGUAGE=en
# ISO 3166-1 alpha-2 (e.g. MY). Required for local/Docker: Xsolla rejects private IPs in X-User-Ip;
# without a public IP you must set country (see admin/payment/token docs).
XSOLLA_PAYSTATION_COUNTRY=

# Xsolla JWT validation
# IMPORTANT: Login project must use RS256 (Publisher Account → Login → Security → JWT signature)
# JWKS URL format: https://login.xsolla.com/api/2/login/projects/{LOGIN_PROJECT_UUID}/public_keys
XSOLLA_JWKS_URL=https://login.xsolla.com/api/projects/YOUR_LOGIN_PROJECT_UUID/jwks.json
XSOLLA_ISSUER=https://login.xsolla.com
XSOLLA_AUDIENCE=

# Optional external catalog/webhook settings
XSOLLA_CATALOG_URL=
XSOLLA_WEBHOOK_SECRET=

# Comma-separated origins, example:
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
